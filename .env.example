# ── Local dev chain (Hardhat) ────────────────────────────────────────────────
# Default Hardhat node RPC. Started by `pnpm chain`.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# ── Keys (Hardhat well-known dev accounts — NEVER use on a real network) ──────
# Account #0 — deployer / protocol admin (holds ORACLE_ROLE + MATCHING_ENGINE_ROLE in MVP).
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Account #1 — gateway operator (oracle + matching engine signer).
GATEWAY_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# Account #2 — node operator (provider) wallet.
NODE_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
# Account #3 — requester (developer) wallet.
REQUESTER_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Deployed contract addresses are written by `deploy:local` to
# packages/contracts/exports/addresses.localhost.json — no need to set them here.

# ── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=8787
# Static API-key -> requester-wallet map for MVP auth (key:wallet,key:wallet).
GATEWAY_API_KEYS=sk-querais-dev:0x90F79bf6EB2c4f870365E785982E1f101E93b906

# ── Node daemon ──────────────────────────────────────────────────────────────
DAEMON_PORT=9444
GATEWAY_WS_URL=ws://127.0.0.1:8787/node
OLLAMA_URL=http://127.0.0.1:11434

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=5173
