{
  "name": "querais",
  "version": "0.1.0",
  "private": true,
  "description": "QueraIS — decentralized P2P AI inference marketplace (MVP vertical slice)",
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --filter \"./packages/**\" typecheck",
    "test": "pnpm -r --filter \"./packages/**\" test",
    "test:coverage": "node --import tsx --test --experimental-test-coverage \"packages/shared/src/**/*.test.ts\" \"packages/matching/src/**/*.test.ts\" \"packages/gateway/src/**/*.test.ts\" \"packages/node-daemon/src/**/*.test.ts\" \"packages/sdk/src/**/*.test.ts\"",
    "clean": "pnpm -r exec rimraf dist tsconfig.tsbuildinfo",
    "chain": "pnpm --filter @querais/contracts chain",
    "deploy:local": "pnpm --filter @querais/contracts deploy:local",
    "deploy:sepolia": "pnpm --filter @querais/contracts deploy:sepolia",
    "dev:gateway": "pnpm --filter @querais/gateway dev",
    "dev:daemon": "pnpm --filter @querais/node-daemon dev",
    "test:contracts": "pnpm --filter @querais/contracts test",
    "test:unit": "pnpm -r --filter \"./packages/**\" --filter \"!@querais/contracts\" --filter \"!@querais/test-e2e\" test",
    "test:e2e": "pnpm --filter @querais/test-e2e e2e",
    "live:sepolia": "pnpm --filter @querais/test-e2e live:sepolia",
    "gateway:sepolia": "pnpm --filter @querais/test-e2e gateway:sepolia",
    "prepare:vm-node": "pnpm --filter @querais/test-e2e prepare:vm-node",
    "demo": "pnpm --filter @querais/test-e2e demo"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
