# QueraIS node — operator config. run-node copies this to .env on first run.
# Full reference: INSTALL.md (shipped next to this file).

# Which network to join: the daemon loads deployments/addresses.<NETWORK>.json.
NETWORK=arbitrumSepolia

# The gateway to serve jobs for.
GATEWAY_WS_URL=wss://gateway.querais.xyz/node

# Your local Ollama (the inference engine actually running the models).
OLLAMA_URL=http://127.0.0.1:11434

# Models to serve, comma-separated Ollama tags (pulled automatically if missing).
# A bare name like `llama3.2` matches Ollama's `llama3.2:latest`.
# Empty = advertise everything Ollama already has locally.
DAEMON_MODELS=llama3.2,gemma3:4b

# QAIS staked on first registration (skin in the game; slashed for bad results).
DAEMON_STAKE_QAIS=2500

# Testnet convenience: auto-claim gas + stake from the gateway faucet when underfunded.
# Works only if the gateway has a faucet configured; otherwise fund the printed wallet
# address manually (the daemon prints it on first boot).
DAEMON_AUTO_FAUCET=true

# ── Wallet ──────────────────────────────────────────────────────────────────
# Leave both unset and the daemon generates an encrypted keystore at
# ~/.querais/keystore.json on first boot. Set a real password before staking
# anything you care about. NEVER share or commit a private key.
#DAEMON_KEYSTORE_PASSWORD=change-me
#NODE_PRIVATE_KEY=

# ── Rarely needed ───────────────────────────────────────────────────────────
# RPC override (the deployment manifest already carries the network's RPC URL).
#RPC_URL=
# Electricity cost per token in wei — sets your auto-price floor.
#DAEMON_ELECTRICITY_WEI=0
