{
  "name": "@querais/shared",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Shared types, schemas, wire protocol, and EIP-712 helpers for the QueraIS protocol. Published as a dependency of @querais/sdk.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShavitR/querais.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@querais/contracts": "workspace:*",
    "viem": "^2.52.2",
    "zod": "^3.24.1"
  }
}
