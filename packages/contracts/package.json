{
  "name": "@querais/contracts",
  "version": "0.2.1",
  "license": "MIT",
  "type": "module",
  "description": "QueraIS smart contracts (QUAISToken, NodeRegistry, JobEscrow, CreditAccount, DisputeResolution, ProtocolTreasury, StakingRewards): ABIs, deployment manifests, and Hardhat 3 tooling. Published as a dependency of @querais/sdk.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShavitR/querais.git",
    "directory": "packages/contracts"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./abis": {
      "types": "./dist/abis.d.ts",
      "default": "./dist/abis.js"
    }
  },
  "files": [
    "dist",
    "contracts",
    "deployments"
  ],
  "scripts": {
    "compile": "hardhat compile",
    "export-abis": "tsx scripts/export-abis.ts",
    "build": "hardhat compile && tsx scripts/export-abis.ts && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:sol": "solhint \"contracts/**/*.sol\"",
    "test": "hardhat test",
    "chain": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "deploy:credit:sepolia": "hardhat run scripts/deploy-credit-account.ts --network arbitrumSepolia",
    "verify:sepolia": "hardhat verify --network arbitrumSepolia",
    "preflight:sepolia": "tsx scripts/preflight.ts",
    "pause": "tsx scripts/pause.ts",
    "allocate": "tsx scripts/allocate.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "dotenv": "^16.4.7",
    "hardhat": "^3.8.0",
    "solhint": "^6.2.1",
    "viem": "^2.52.2"
  }
}
